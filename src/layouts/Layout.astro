---
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
        *, *::before, *::after { box-sizing: border-box; }
        html { overflow-x: hidden; width: 100%; }
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            margin: 0;
            padding: 0;
            width: 100%;
        }
        .hero-gradient {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
            padding: 5rem 5%;
            text-align: center;
        }
        .hero-title {
            font-size: clamp(2.5rem, 5vw, 3.75rem);
            font-weight: 700;
            margin: 0 0 1.5rem;
            background: linear-gradient(to right, #fff, #22d3ee);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-tagline {
            font-size: 1.25rem;
            color: #cbd5e1;
            margin: 0;
        }
        .tab-container {
            width: 100%;
            max-width: 1600px;
            margin: 0 auto;
            padding: 40px;
        }
        .tab-nav {
            display: flex;
            flex-wrap: wrap;
            border-bottom: 2px solid #334155;
            margin-bottom: 30px;
            gap: 5px;
            background: rgba(30, 41, 59, 0.5);
            border-radius: 12px 12px 0 0;
            padding: 10px;
        }
        .tab-button {
            background: none;
            border: none;
            padding: 12px 20px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 500;
            color: #94a3b8;
            border-bottom: 3px solid transparent;
            transition: all 0.3s ease;
            border-radius: 8px;
            font-family: inherit;
        }
        .tab-button:hover { color: #06b6d4; background-color: rgba(6, 182, 212, 0.1); }
        .tab-button.active { color: #06b6d4; border-bottom-color: #06b6d4; background-color: rgba(6, 182, 212, 0.15); }
        .tab-content {
            display: none;
            animation: fadeIn 0.3s ease-in;
            background: rgba(30, 41, 59, 0.3);
            border-radius: 12px;
            padding: 30px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(51, 65, 85, 0.3);
        }
        .tab-content.active { display: block; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .section-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 25px;
            border-bottom: 2px solid #06b6d4;
            padding-bottom: 15px;
            background: linear-gradient(135deg, #f1f5f9 0%, #06b6d4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .sub-tab-nav {
            display: flex;
            flex-wrap: wrap;
            border-bottom: 1px solid #334155;
            margin-bottom: 20px;
            gap: 5px;
            background: rgba(51, 65, 85, 0.3);
            border-radius: 8px;
            padding: 8px;
        }
        .sub-tab-button {
            background: none;
            border: none;
            padding: 8px 16px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: #94a3b8;
            border-bottom: 2px solid transparent;
            transition: all 0.3s ease;
            border-radius: 6px;
            font-family: inherit;
        }
        .sub-tab-button:hover { color: #06b6d4; background-color: rgba(6, 182, 212, 0.1); }
        .sub-tab-button.active { color: #06b6d4; border-bottom-color: #06b6d4; background-color: rgba(6, 182, 212, 0.15); }
        .sub-tab-content { display: none; animation: fadeIn 0.3s ease-in; }
        .sub-tab-content.active { display: block; }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 12px;
            overflow: hidden;
            table-layout: fixed;
            word-wrap: break-word;
        }
        .table-wrapper { overflow-x: auto; margin: 20px 0; width: 100%; }
        th, td {
            border: 1px solid #334155;
            padding: 15px;
            text-align: left;
            color: #fff;
            font-weight: 400;
            font-size: 15px;
            line-height: 1.5;
            word-break: break-word;
            overflow-wrap: break-word;
        }
        th {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            font-weight: 600;
            color: #06b6d4;
        }
        td { background: rgba(15, 23, 42, 0.6); }
        .links-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 25px 0;
        }
        .link-item {
            padding: 20px;
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(51, 65, 85, 0.6) 100%);
            border-radius: 12px;
            text-align: center;
            border: 1px solid rgba(6, 182, 212, 0.2);
            transition: all 0.3s ease;
        }
        .link-item:hover { transform: translateY(-5px); border-color: #06b6d4; box-shadow: 0 10px 25px rgba(6, 182, 212, 0.15); }
        p, li, div { color: #fff; font-weight: 400; font-size: 16px; line-height: 1.6; }
        a { color: #06b6d4; text-decoration: none; transition: color 0.3s ease; word-break: break-word; }
        a:hover { color: #0891b2; }
        h3 { color: #f1f5f9; font-size: 22px; font-weight: 600; margin-bottom: 16px; }
        h4 { color: #e2e8f0; font-size: 18px; font-weight: 600; margin: 20px 0 10px; }
        ul { padding-left: 20px; }
        .principles-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .principles-list li {
            padding: 16px 20px;
            margin-bottom: 8px;
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.4) 0%, rgba(51, 65, 85, 0.2) 100%);
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .principles-list li:hover {
            transform: translateX(8px);
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.6) 0%, rgba(51, 65, 85, 0.4) 100%);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.15);
        }
        .context-link {
            display: inline-flex;
            align-items: center;
            margin-left: 8px;
            padding: 4px 8px;
            background: rgba(6, 182, 212, 0.1);
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
        }
        .context-link::before { content: "🤓"; margin-right: 4px; }
        .social-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 3rem;
        }
        .social-links a {
            font-weight: 600;
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            transition: all 0.3s ease;
        }
        .btn-primary { background: #06b6d4; color: #0f172a; }
        .btn-primary:hover { background: #22d3ee; color: #0f172a; }
        .btn-outline { border: 1px solid #06b6d4; color: #22d3ee; }
        .btn-outline:hover { background: #06b6d4; color: #0f172a; }
        .travel-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin: 20px 0;
        }
        @media (max-width: 768px) {
            .tab-container { padding: 10px; }
            .tab-nav { flex-direction: column; gap: 0; }
            .tab-button {
                text-align: left;
                border-bottom: none;
                border-left: 3px solid transparent;
                padding: 15px 20px;
                font-size: 18px;
            }
            .tab-button.active { border-left-color: #06b6d4; border-bottom-color: transparent; }
            .section-title { font-size: 20px; }
            .links-grid { grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; }
            .link-item { padding: 8px; font-size: 14px; }
            th, td { padding: 8px; font-size: 14px; }
        }
    </style>
</head>
<body>
    <slot />
    <script is:inline>
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
        }
        function showSubTab(name) {
            document.querySelectorAll('.sub-tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.sub-tab-button').forEach(b => b.classList.remove('active'));
            document.getElementById(name).classList.add('active');
            event.target.classList.add('active');
        }
    </script>
</body>
</html>
