---
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
        :root {
            --bg: #fdfdfd;
            --fg: #282728;
            --accent: #006cac;
            --muted: #e6e6e6;
            --border: #ece9e9;
        }
        [data-theme="dark"] {
            --bg: #212737;
            --fg: #eaedf3;
            --accent: #ff6b01;
            --muted: #343f60;
            --border: #4a5568;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { overflow-y: scroll; scroll-behavior: smooth; }
        body {
            background: var(--bg);
            color: var(--fg);
            font-family: 'IBM Plex Mono', monospace;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.7;
            font-size: 16px;
        }
        ::selection { background: var(--accent); color: var(--bg); }

        /* Theme toggle */
        .theme-toggle {
            position: fixed;
            top: 1rem;
            right: 1rem;
            background: var(--muted);
            border: 1px solid var(--border);
            border-radius: 50%;
            width: 44px;
            height: 44px;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
            transition: opacity 0.2s;
        }
        .theme-toggle:hover { opacity: 0.7; }

        /* Header / Hero */
        .hero {
            max-width: 48rem;
            margin: 0 auto;
            padding: 4rem 1.5rem 2rem;
        }
        .hero-title {
            font-size: clamp(2rem, 4vw, 2.75rem);
            font-weight: 700;
            color: var(--fg);
            margin-bottom: 0;
            letter-spacing: -0.02em;
        }
        .hero-subtitle {
            font-size: 0.9rem;
            font-weight: 400;
            opacity: 0.6;
            letter-spacing: 0.02em;
            margin-top: 0.15rem;
            margin-bottom: 0.75rem;
        }
        .hero-tagline {
            color: var(--fg);
            opacity: 0.7;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        /* Tab container */
        .tab-container {
            max-width: 48rem;
            margin: 0 auto;
            padding: 0 1.5rem 4rem;
        }
        .tab-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 2rem;
        }
        .tab-button {
            background: none;
            border: none;
            padding: 0.75rem 1.25rem;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--fg);
            opacity: 0.5;
            border-bottom: 2px solid transparent;
            transition: opacity 0.2s, color 0.2s, text-decoration-color 0.2s;
            font-family: inherit;
            letter-spacing: 0.02em;
        }
        .tab-button:hover { opacity: 0.8; }
        .tab-button.active {
            opacity: 1;
            color: var(--accent);
            text-decoration: underline;
            text-decoration-style: wavy;
            text-underline-offset: 8px;
            text-decoration-thickness: 2px;
            border-bottom-color: transparent;
        }

        /* Tab content */
        .tab-content { display: none; animation: fadeIn 0.2s ease-in; }
        .tab-content.active { display: block; }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Section titles */
        .section-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--border);
            color: var(--fg);
        }
        .section-title:has(+ .section-subtitle) {
            border-bottom: none;
            padding-bottom: 0;
        }
        .section-subtitle {
            font-size: 0.85rem;
            font-weight: 400;
            opacity: 0.6;
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--border);
        }

        /* Sub tabs */
        .sub-tab-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 1.5rem;
        }
        .sub-tab-button {
            background: none;
            border: none;
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--fg);
            opacity: 0.5;
            border-bottom: 2px solid transparent;
            transition: opacity 0.2s, color 0.2s;
            font-family: inherit;
        }
        .sub-tab-button:hover { opacity: 0.8; }
        .sub-tab-button.active {
            opacity: 1;
            color: var(--accent);
            text-decoration: underline;
            text-decoration-style: wavy;
            text-underline-offset: 6px;
            text-decoration-thickness: 1.5px;
        }
        .sub-tab-content { display: none; animation: fadeIn 0.2s ease-in; }
        .sub-tab-content.active { display: block; }

        /* Tables */
        .table-wrapper { overflow-x: auto; margin: 1.25rem 0; }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.25rem 0;
            font-size: 0.85rem;
        }
        th, td {
            border: 1px solid var(--border);
            padding: 0.5rem 0.75rem;
            text-align: left;
            color: var(--fg);
            line-height: 1.5;
            word-break: break-word;
        }
        th {
            font-weight: 600;
            background: var(--muted);
        }
        td:first-child { white-space: nowrap; }

        /* Links grid */
        .links-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
            margin: 1.25rem 0;
        }
        .link-item {
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: 4px;
            text-align: center;
            transition: border-color 0.2s;
        }
        .link-item:hover { border-color: var(--accent); }

        /* Typography */
        p, li, div { color: var(--fg); font-size: 0.9rem; line-height: 1.7; }
        a {
            color: var(--fg);
            text-decoration: underline;
            text-decoration-style: dashed;
            text-underline-offset: 4px;
            padding-block: 3px;
            transition: color 0.2s;
        }
        a:hover { color: var(--accent); }
        h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--fg); }
        h4 { font-size: 0.95rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: var(--fg); }
        ul { padding-left: 1.25rem; }
        li { margin-bottom: 0.25rem; }
        li::marker { color: var(--accent); }

        /* Principles list */
        .principles-list {
            list-style: none;
            padding: 0;
        }
        .principles-list li {
            padding: 0.6rem 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.9rem;
        }
        .principles-list li:last-child { border-bottom: none; }

        /* Context link */
        .context-link {
            font-size: 0.8rem;
            margin-left: 0.25rem;
        }

        /* Social links */
        .social-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin: 1.5rem 0;
        }
        .social-links a {
            font-weight: 500;
            padding: 0.5rem 1rem;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            border: 1px solid var(--border);
            border-radius: 4px;
            font-size: 0.85rem;
            text-decoration: none;
        }
        .btn-primary {
            background: var(--accent);
            color: var(--bg);
            border-color: var(--accent);
        }
        .btn-primary:hover { opacity: 0.85; color: var(--bg); }
        .btn-outline { color: var(--fg); }
        .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

        /* Travel grid */
        .travel-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.5rem;
            margin: 1.25rem 0;
        }

        /* Stats row */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.75rem;
            margin: 1.5rem 0;
        }
        .stat-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1rem 0.5rem;
            border: 1px solid var(--border);
            border-radius: 4px;
        }
        .stat-num { font-size: 1.5rem; font-weight: 700; color: var(--accent); }
        .stat-label { font-size: 0.75rem; opacity: 0.6; margin-top: 0.25rem; }

        /* Region blocks */
        .region-block { margin-bottom: 2rem; }

        /* Country chips */
        .chip-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
        .chip {
            display: inline-block;
            padding: 0.3rem 0.75rem;
            border: 1px solid var(--border);
            border-radius: 999px;
            font-size: 0.8rem;
            text-decoration: none;
            color: var(--fg);
            transition: border-color 0.2s, color 0.2s;
        }
        .chip:hover { border-color: var(--accent); color: var(--accent); }

        /* Pull quote */
        .pull-quote {
            border-left: 3px solid var(--accent);
            margin: 2rem 0 0;
            padding: 0.75rem 1.25rem;
            font-style: italic;
            opacity: 0.8;
        }

        /* Footer */
        footer {
            max-width: 48rem;
            margin: auto auto 0;
            padding: 2rem 1.5rem;
            width: 100%;
            text-align: center;
            font-size: 0.75rem;
            opacity: 0.5;
            border-top: 1px solid var(--border);
        }

        /* Mobile */
        @media (max-width: 640px) {
            .tab-nav, .sub-tab-nav { gap: 0; }
            .tab-button { padding: 0.6rem 0.75rem; font-size: 0.8rem; }
            .links-grid { grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); }
            th, td { padding: 0.4rem 0.5rem; font-size: 0.8rem; }
            .stats-row { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>
    <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <span id="theme-icon">🌙</span>
    </button>
    <slot />
    <footer>
        Copyright &copy; {new Date().getFullYear()} | All rights reserved.
    </footer>
    <script is:inline>
        function toggleTheme() {
            const html = document.documentElement;
            const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
            html.dataset.theme = next;
            localStorage.setItem('theme', next);
            document.getElementById('theme-icon').textContent = next === 'dark' ? '☀️' : '🌙';
        }
        (function() {
            const saved = localStorage.getItem('theme') ||
                (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.dataset.theme = saved;
            document.getElementById('theme-icon').textContent = saved === 'dark' ? '☀️' : '🌙';
        })();
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
        }
        function showSubTab(name) {
            document.querySelectorAll('.sub-tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.sub-tab-button').forEach(b => b.classList.remove('active'));
            document.getElementById(name).classList.add('active');
            event.target.classList.add('active');
        }
    </script>
</body>
</html>
